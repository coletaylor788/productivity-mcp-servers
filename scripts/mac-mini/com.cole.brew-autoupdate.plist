<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cole.brew-autoupdate</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/brew-autoupdate.sh</string>
    </array>

    <!-- Run every Sunday at 03:00 local time -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>0</integer>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- If the Mini was off at 03:00 Sunday, run as soon as the LaunchAgent loads -->
    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/puddles/Library/Logs/brew-autoupdate.launchd.out</string>
    <key>StandardErrorPath</key>
    <string>/Users/puddles/Library/Logs/brew-autoupdate.launchd.err</string>
</dict>
</plist>
