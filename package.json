{
  "name": "puddles",
  "private": true,
  "version": "0.0.0",
  "description": "Puddles personal-agent monorepo: MCP servers, OpenClaw plugins, and host setup",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" --filter \"./openclaw-plugins/**\" build",
    "test": "pnpm -r --filter \"./packages/**\" --filter \"./openclaw-plugins/**\" test",
    "lint": "pnpm -r --filter \"./packages/**\" --filter \"./openclaw-plugins/**\" lint"
  },
  "packageManager": "pnpm@10.31.0",
  "pnpm": {
    "overrides": {
      "uuid@<14.0.0": ">=14.0.0"
    }
  }
}
