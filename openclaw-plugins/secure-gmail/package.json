{
  "name": "secure-gmail",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw plugin: wraps Gmail MCP tools with mcp-hooks ingress security",
  "type": "module",
  "main": "dist/plugin.js",
  "types": "dist/plugin.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run --config vitest.all.config.ts",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "mcp-hooks": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "keytar": "^7.9.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
